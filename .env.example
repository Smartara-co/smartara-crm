# Get these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key (Settings → API → service_role) — server-only, never
# expose to the browser. Used by the /api/leads webhook to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared secret your website's backend sends when posting to /api/leads.
# Generate a random string, e.g. `openssl rand -hex 32`.
LEADS_WEBHOOK_SECRET=your-random-webhook-secret
